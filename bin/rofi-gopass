#!/usr/bin/env bash

entries=$(gopass ls --flat 2>/dev/null)
[ -z "$entries" ] && exit 1

entry=$(echo "$entries" | rofi -dmenu -p "gopass" -i -fuzzy)
[ -z "$entry" ] && exit 1

gopass show -o "$entry" | tr -d '\n' | wl-copy

notify-send "gopass" "Copied '$entry'" -t 2000 2>/dev/null
(sleep 45 && wl-copy -c) &
